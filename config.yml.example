# Copy this file to `config.yml` and fill in secrets locally.
# This example contains placeholder values only and is safe to commit.

# M0ST Configuration
# Copy to config.yml and edit: cp config.yml.example config.yml

sqlite:
  db_path: storage/metadata.db

tools:
  r2_path: ""
  gdb_path: ""
  ghidra_path: ""        # path to Ghidra analyzeHeadless script (optional)
  windbg_path: ""        # path to cdb.exe for Windows dynamic tracing (optional)
  x64dbg_path: ""        # path to x64dbg.exe for Windows tracing (optional)

# Dynamic analysis configuration
dynamic:
  strategy: ""            # auto | gdb | docker | windbg | x64dbg (empty = auto-detect)
  docker_image: "m0st/gdb-trace:latest"  # Docker image for container-based tracing

pipeline:
  event_timeout_seconds: 10.0

# LLM configuration (optional - falls back to classical heuristics)
llm:
  provider: openai          # openai | anthropic | mistral | local | none
  model: gpt-4o-mini             # e.g. gpt-4o, claude-sonnet-4-20250514, mistral-large-latest
  api_key: ""             # set via env var recommended: OPENAI_API_KEY, ANTHROPIC_API_KEY
  base_url: ""            # for local/Ollama: http://localhost:11434/v1
  temperature: 0.2
  max_tokens: 4096

# GNN model configuration (optional)
gnn:
  model_path: ""          # path to trained .pt model checkpoint
  architecture: gat       # gat | graphsage | gine
  hidden_dim: 128
  out_dim: 64
  device: cpu             # cpu | cuda
  feature_mode: full      # full | minimal (set minimal for 4-feature training)
  input_dim: null         # optional explicit input dim; null auto-detects
